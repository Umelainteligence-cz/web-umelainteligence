---
import { SITE } from '@/lib/constants';

const year = new Date().getFullYear();
---

<footer class="bg-cream px-6 lg:px-12 py-6 border-t border-cream-dark/50">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <p class="text-sm text-ink-light/50">&copy; {year} {SITE.title}</p>
    <div class="w-1 h-1 rounded-full bg-emerald/40"></div>
  </div>
</footer>
