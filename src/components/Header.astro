---
import { SITE } from '@/lib/constants';
---

<header class="relative z-20 px-6 lg:px-12 py-5 bg-cream/80 backdrop-blur-sm">
  <nav class="max-w-7xl mx-auto flex items-center justify-between">
    <a href="/" class="group flex items-center gap-2.5">
      <span class="inline-block w-2 h-5 bg-emerald rounded-sm transition-transform group-hover:scale-y-110"></span>
      <span class="text-lg font-semibold text-ink tracking-tight">{SITE.title}</span>
    </a>
  </nav>
</header>
