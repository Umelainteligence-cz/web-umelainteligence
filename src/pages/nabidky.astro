---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/constants';

const proposals = [
  {
    client: 'SANO — Moderní výživa zvířat',
    project: 'Strategická AI transformace',
    date: '13. 03. 2026',
    variants: [
      { label: 'Tmavý motiv', lang: 'CZ', href: '/SANO-nabidka-2026-03-12-dark.html' },
      { label: 'Světlý motiv', lang: 'CZ', href: '/SANO-nabidka-2026-03-12-light.html' },
      { label: 'Dark theme', lang: 'EN', href: '/SANO-nabidka-2026-03-12-dark-en.html' },
      { label: 'Light theme', lang: 'EN', href: '/SANO-nabidka-2026-03-12-light-en.html' },
    ],
  },
];
---

<BaseLayout title={`Nabídky — ${SITE.title}`} description="Přehled veřejných nabídek a návrhů spolupráce">
  <section class="max-w-4xl mx-auto px-6 lg:px-12 py-16">
    <div class="w-12 h-0.5 bg-emerald mb-8" style="animation: draw-line 0.6s ease-out both; transform-origin: left;"></div>

    <h1 class="text-4xl font-bold text-ink mb-4" style="animation: fade-up 0.8s ease-out both;">
      Nabídky
    </h1>
    <p class="text-lg text-ink-light mb-12" style="animation: fade-up 0.8s ease-out 0.2s both;">
      Veřejné návrhy spolupráce
    </p>

    <div class="space-y-8" style="animation: fade-up 0.8s ease-out 0.4s both;">
      {proposals.map((p) => (
        <article class="border border-cream-dark rounded-lg p-6 lg:p-8 bg-cream/50">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
            <div>
              <h2 class="text-2xl font-bold text-ink">{p.client}</h2>
              <p class="text-ink-light">{p.project}</p>
            </div>
            <span class="text-sm text-ink-light/70 whitespace-nowrap">{p.date}</span>
          </div>

          <div class="flex flex-wrap gap-3 mt-6">
            {p.variants.map((v) => (
              <a
                href={v.href}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-md border border-cream-dark bg-cream text-ink hover:bg-emerald hover:text-white hover:border-emerald transition-colors"
              >
                <span class="text-xs uppercase tracking-wider text-ink-light/60">{v.lang}</span>
                {v.label}
              </a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
