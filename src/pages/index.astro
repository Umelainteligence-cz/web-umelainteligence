---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/constants';
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <section class="min-h-[calc(100vh-8rem)] flex items-center justify-center px-4">
    <h1 class="max-w-3xl text-4xl md:text-6xl font-bold leading-tight text-center text-gray-900">
      Nechte šikovné lidi přemýšlet, ne kopírovat data.
    </h1>
  </section>
</BaseLayout>
