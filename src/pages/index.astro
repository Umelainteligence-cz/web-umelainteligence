---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/constants';
import heroImage from '@/assets/hero.png';
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <section class="hero-gradient relative min-h-[calc(100vh-4rem)] overflow-hidden">
    <!-- Decorative golden ratio arc -->
    <div class="absolute top-12 right-12 w-48 h-48 rounded-full border border-gold/20 hidden lg:block"
      style="animation: fade-in 1.5s ease-out 0.8s both;"
    ></div>
    <div class="absolute top-20 right-20 w-32 h-32 rounded-full border border-gold/15 hidden lg:block"
      style="animation: fade-in 1.5s ease-out 1s both;"
    ></div>

    <!-- Main content grid -->
    <div class="max-w-7xl mx-auto px-6 lg:px-12 h-full min-h-[calc(100vh-4rem)] grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-0 items-center">

      <!-- Left: Image -->
      <div class="relative flex items-center justify-center lg:justify-start order-2 lg:order-1 pb-8 lg:pb-0"
        style="animation: fade-in 1s ease-out 0.5s both;"
      >
        <!-- Emerald accent bar behind image -->
        <div class="absolute left-[15%] top-1/2 -translate-y-1/2 w-2 h-3/5 bg-emerald/10 rounded-full hidden lg:block"></div>

        <Image
          src={heroImage}
          alt="UměláInteligence.cz - Platforma pro českou AI komunitu"
          class="relative w-full max-w-md lg:max-w-lg xl:max-w-xl h-auto rounded-sm"
          widths={[480, 640, 800]}
          sizes="(max-width: 1024px) 90vw, 45vw"
          quality={85}
          loading="eager"
        />
      </div>

      <!-- Right: Text -->
      <div class="pt-16 lg:pt-0 lg:pl-12 max-w-xl order-1 lg:order-2 lg:ml-auto" style="animation: fade-up 0.8s ease-out both;">
        <!-- Accent line -->
        <div class="w-12 h-0.5 bg-emerald mb-8" style="animation: draw-line 0.6s ease-out 0.3s both; transform-origin: left;"></div>

        <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] xl:text-6xl font-bold leading-[1.1] tracking-tight text-ink">
          Nechte šikovné lidi
          <span class="block">přemýšlet,</span>
          <span class="block text-emerald">ne kopírovat data.</span>
        </h1>

        <p class="mt-8 text-lg lg:text-xl text-ink-light leading-relaxed max-w-md"
          style="animation: fade-up 0.8s ease-out 0.4s both;"
        >
          Pro všechny, kteří přemýšlí 500 let dopředu
        </p>

        <!-- Subtle decorative detail -->
        <div class="mt-12 flex items-center gap-3"
          style="animation: fade-up 0.8s ease-out 0.6s both;"
        >
          <div class="w-1.5 h-1.5 rounded-full bg-emerald"></div>
          <span class="text-sm tracking-widest uppercase text-ink-light/60">UměláInteligence.cz</span>
        </div>
      </div>
    </div>

    <!-- Bottom edge accent -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cream-dark to-transparent"></div>
  </section>
</BaseLayout>
